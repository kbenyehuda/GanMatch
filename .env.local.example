# Mapbox - Get your token at https://account.mapbox.com/
# Can also be set in system environment variables
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Supabase - Create project at https://supabase.com (choose Israel/Tel Aviv region)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Required for process_user_inputs.py (Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
