SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# LLM extraction (optional): set OPENAI_API_KEY to use GPT. Set SKIP_LLM=1 to use rule-based only (no API cost).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Server-side toggle (API route)
CONTACT_REVIEWER_ENABLED=true

# Client-side toggle (UI) - optional now, but recommended
NEXT_PUBLIC_CONTACT_REVIEWER_ENABLED=true