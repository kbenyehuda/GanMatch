# Copy to .env.local for local dev.
# In production, set these via your hosting provider’s Environment Variables UI.
#
# IMPORTANT:
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# - Never put secrets in NEXT_PUBLIC_ variables.

# Mapbox - Get a free token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Supabase (public) - Create project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Contact reviewer (email relay) - server-side only (do NOT expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL="GanMatch <noreply@yourdomain.com>"

# Admin triage access (comma-separated emails, case-insensitive)
ADMIN_EMAILS=kbenyehuda2@gmail.com

# Feature toggles
# Server-side toggle (API route)
CONTACT_REVIEWER_ENABLED=false
# Client-side toggle (UI)
NEXT_PUBLIC_CONTACT_REVIEWER_ENABLED=true

